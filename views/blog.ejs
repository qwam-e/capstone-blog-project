<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Travel Blog</title>
<link rel="icon" type="image/x-icon" href="/images/favcon.ico">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<style>

/* RESET */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* GENERAL */
body {
  font-family: 'Poppins', sans-serif;
  background: #020617;
  color: #e5e7eb;
  padding-top: 100px; /* space for floating navbar */
}

/* FLOATING NAVBAR */
.navbar {
  position: fixed;
  top: 15px;
  left: 50%;
  transform: translateX(-50%);

  width: 90%;
  /* max-width: 1200px; */

  z-index: 1000;

  padding: 15px 25px;

  background: rgba(15, 23, 42, 0.75);
  backdrop-filter: blur(12px);

  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.05);

  box-shadow: 0 8px 30px rgba(0,0,0,0.3);
}

/* NAV TOP */
.nav-top {
  display: flex;
  justify-content: space-between;
  align-items: center;

  font-size: 13px;
  color: #94a3b8;
}

/* LOGO */
.logo {
  font-family: 'Playfair Display', serif;
  font-size: 20px;
  color: #fff;
}

/* NAV LINKS */
.nav-links {
  display: flex;
  gap: 20px;
  margin-top: 10px;
}

.nav-links a,
.nav-links span {
  text-decoration: none;
  color: #cbd5f5;
  font-size: 14px;
  cursor: pointer;
  transition: 0.3s;
}

.nav-links a:hover,
.nav-links span:hover {
  color: #f97316;
}

/* HERO */
.hero {
  position: relative;
  margin: 30px auto;
  width: 90%;
  /* max-width: 1200px; */

  border-radius: 12px;
  overflow: hidden;
}

.hero img {
  width: 100%;
  height: 420px;
  object-fit: cover;
  filter: brightness(60%);
}

/* HERO TEXT */
.hero-content {
  position: absolute;
  bottom: 30px;
  left: 30px;
  max-width: 600px;
}

.hero-content h1 {
  font-family: 'Playfair Display', serif;
  font-size: 38px;
  margin-bottom: 10px;
}

.hero-content p {
  font-size: 14px;
  color: #cbd5f5;
  margin-bottom: 15px;
}

.hero-content a {
  color: #f97316;
  text-decoration: none;
  font-weight: 500;
}

/* GRID */
.grid {
  width: 90%;
  /* max-width: 1200px; */
  margin: auto;

  display: grid;
  grid-template-columns: repeat(2, 1fr); /* force 2 per row */
  gap: 25px;
  padding-bottom: 40px;
}

/* CARD */
.card {
  background: #1e293b;
  border-radius: 10px;
  overflow: hidden;

  display: flex;
  flex-direction: column;

  transition: 0.3s;
}

.card:hover {
  transform: translateY(-6px);
}

/* IMAGE */
.card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

/* CONTENT */
.card-content {
  padding: 15px;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.card-content h3 {
  font-size: 18px;
  margin-bottom: 8px;
}

.card-content p {
  font-size: 13px;
  color: #94a3b8;
  margin-bottom: 12px;
  flex-grow: 1;
}

.card-content a {
  color: #f97316;
  text-decoration: none;
  font-size: 13px;
}

.card-content a:hover {
  text-decoration: underline;
}

/* EMPTY */
.empty {
  text-align: center;
  margin-top: 50px;
  color: #94a3b8;
}

/* RESPONSIVE */
@media (max-width: 768px) {
  .grid {
    grid-template-columns: 1fr;
  }

  .hero img {
    height: 300px;
  }

  .hero-content h1 {
    font-size: 26px;
  }
}

</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">

  <div class="nav-top">
    <span>Subscribe</span>
    <div class="logo">Travel Blog</div>
    <span>Sign up</span>
  </div>

  <div class="nav-links">
    <a href="/">Home</a>
    <span>Technology</span>
    <span>Design</span>
    <span>Culture</span>
    <span>Business</span>
    <span>Travel</span>
  </div>

</div>

<!-- HERO -->
<% if (posts.length > 0) { %>
<div class="hero">

  <img src="/uploads/<%= posts[0].image || 'default.jpg' %>">

  <div class="hero-content">
    <h1><%= posts[0].title %></h1>
    <p><%= posts[0].hook %></p>
    <a href="/post/<%= posts[0].id %>">Continue reading →</a>
  </div>

</div>
<% } else { %>
  <p class="empty">No posts yet</p>
<% } %>

<!-- POSTS GRID -->
<div class="grid">

  <% posts.slice(1).forEach(post => { %>

    <div class="card">

      <img src="/uploads/<%= post.image || 'default.jpg' %>">

      <div class="card-content">
        <h3><%= post.title %></h3>
        <p><%= post.hook %></p>
        <a href="/post/<%= post.id %>">Continue reading →</a>
      </div>

    </div>

  <% }) %>

</div>

</body>
</html>