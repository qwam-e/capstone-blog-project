<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard</title>
<link rel="stylesheet" href="/styles/main.css">
<link rel="stylesheet" href="/styles/navbar.css">
<link rel="stylesheet" href="/styles/footer.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
body {
  background: linear-gradient(rgba(0,0,0,0.9)),
              url("/images/kente.jpg");
  background-size: cover;
  background-position: center;
}

/* PAGE */
.dashboard-container {
  max-width: 1100px;
  margin: 40px auto;
  padding: 20px;
}

/* HEADER */
.dashboard-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25px;
}

.dashboard-title {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
}

/* CREATE BUTTON */
.create-btn {
  background: #22c55e;
  color: white;
  padding: 10px 15px;
  border-radius: 6px;
  text-decoration: none;
  font-size: 14px;
}

.create-btn:hover {
  background: #16a34a;
}

/* GRID */
.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}

/* CARD */
.post-card {
  background: #1e293b;
  border-radius: 10px;
  overflow: hidden;
  transition: 0.3s;
}

.post-card:hover {
  transform: translateY(-5px);
}

/* IMAGE */
.post-card img {
  width: 100%;
  height: 180px;
  object-fit: cover;
}

/* CONTENT */
.post-content {
  padding: 15px;
}

.post-content h3 {
  font-size: 18px;
  margin-bottom: 10px;
}

.post-content p {
  font-size: 13px;
  color: #94a3b8;
  margin-bottom: 15px;
}

/* ACTIONS */
.post-actions {
  display: flex;
  gap: 10px;
}

/* BUTTONS */
.edit-btn {
  flex: 1;
  text-align: center;
  background: #2563eb;
  color: white;
  padding: 8px;
  border-radius: 5px;
  text-decoration: none;
  font-size: 13px;
}

.edit-btn:hover {
  background: #1d4ed8;
}

.delete-btn {
  flex: 1;
  background: #dc2626;
  border: none;
  color: white;
  padding: 8px;
  border-radius: 5px;
  cursor: pointer;
  font-size: 13px;
}

.delete-btn:hover {
  background: #b91c1c;
}

/* EMPTY STATE */
.empty-state {
  text-align: center;
  color: #94a3b8;
  margin-top: 50px;
}

</style>
</head>

<body>

<%- include("partials/admin_nav") %>

<div class="dashboard-container">

  <div class="dashboard-header">
    <h1 class="dashboard-title">Admin Dashboard</h1>

    <a href="/compose" class="create-btn">+ New Post</a>
  </div>

<% if (!posts || posts.length === 0) { %>

  <div class="empty-state">
    <p>No posts yet. Start creating!</p>
  </div>

<% } else { %>

  <div class="dashboard-grid">

    <% posts.forEach(post => { %>

      <div class="post-card">

        <img src="/uploads/<%= post.image || 'default.jpg' %>">

        <div class="post-content">
          <h3><%= post.title %></h3>
          <p><%= post.hook || "No description available" %></p>

          <div class="post-actions">

            <a href="/edit/<%= post.id %>" class="edit-btn">Edit</a>

            <form action="/delete/<%= post.id %>" method="POST"
              onsubmit="return confirm('Delete this post?');"
              style="flex:1;">

              <button class="delete-btn">Delete</button>

            </form>

          </div>
        </div>

      </div>

    <% }) %>

  </div>

<% } %>

</div>

</body>
</html>