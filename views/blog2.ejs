<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="styles/blog.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<title>Travel Blog</title>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">
  <div class="nav-top">
    <span>Subscribe</span>
    <div class="logo">Blog</div>
    <span>Sign up</span>
  </div>

  <div class="nav-links">
    <span><a href="/">Home</a></span>
    <span>Technology</span>
    <span>Design</span>
    <span>Culture</span>
    <span>Business</span>
    <span>Travel</span>
  </div>
</div>

<!-- HERO -->
<% if (posts.length > 0) { %>
<div class="hero">
  <h1><%= posts[0].title %></h1>
  <p><%= posts[0].hook %></p>
  <a href="/post/<%= posts[0].id %>">Continue reading...</a>
</div>
<% } else { %>
  <p class="empty">No posts yet</p>
<% } %>

<!-- GRID -->
<div class="grid">

  <% posts.slice(1,3).forEach(post => { %>
    <div class="card">
      <div class="card-content">
        <h3><%= post.title %></h3>
        <p><%= post.hook %></p>
        <a href="/post/<%= post.id %>">Continue reading →</a>
      </div>

      <img src="/uploads/<%= post.image || 'default.jpg' %>">
    </div>
  <% }) %>

</div>

</body>
</html>